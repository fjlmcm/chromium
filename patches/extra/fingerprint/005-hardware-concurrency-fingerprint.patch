+#include "base/strings/string_number_conversions.h"
+#include "components/ungoogled/ungoogled_switches.h"
 
 namespace blink {
 
 unsigned NavigatorConcurrentHardware::hardwareConcurrency() const {
+  const base::CommandLine* command_line = base::CommandLine::ForCurrentProcess();
+
+  // Check for explicitly specified hardware concurrency
+  if (command_line->HasSwitch(switches::kFingerprintHardwareConcurrency)) {
+    std::string value = command_line->GetSwitchValueASCII(switches::kFingerprintHardwareConcurrency);
+    unsigned custom_concurrency;
+    if (base::StringToUint(value, &custom_concurrency) && custom_concurrency > 0) {
+      return custom_concurrency;
+    }
+  }
+
+  // Calculate from fingerprint if available
+  if (command_line->HasSwitch(switches::kFingerprint)) {
+    std::string fingerprint_str = command_line->GetSwitchValueASCII(switches::kFingerprint);
+    uint32_t fingerprint;
+    if (base::StringToUint(fingerprint_str, &fingerprint)) {
+      // Generate a reasonable number of cores (2, 4, 6, 8, 12, 16)
+      static const unsigned core_options[] = {2, 4, 6, 8, 12, 16};
+      return core_options[fingerprint % (sizeof(core_options) / sizeof(core_options[0]))];
+    }
+  }
+
+  // Return actual processor count as fallback
   return static_cast<unsigned>(base::SysInfo::NumberOfProcessors());
 }
 
