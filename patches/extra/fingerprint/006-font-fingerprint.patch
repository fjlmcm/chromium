+  const base::CommandLine* command_line = base::CommandLine::ForCurrentProcess();
+  if (command_line->HasSwitch(switches::kFingerprint)) {
+    // Define system default fonts that should always be available
+    static const char* kSystemDefaultFonts[] = {
+      "Arial",
+      "Times New Roman",
+      "Courier New",
+      "Helvetica",
+      "Times",
+      "Courier",
+      "Georgia",
+      "Verdana",
+      "Tahoma",
+      "Trebuchet MS",
+      "Impact",
+      "Comic Sans MS",
+      "Palatino",
+      "Lucida Grande",
+      "Lucida Sans Unicode"
+    };
+
+    if (creation_params.CreationType() == kCreateFontByFamily) {
+      // Check if this is a system default font
+      bool is_system_default = false;
+      const String& family_name = creation_params.Family();
+      for (const char* font : kSystemDefaultFonts) {
+        if (family_name == font) {
+          is_system_default = true;
+          break;
+        }
+      }
+
+      // Apply fingerprinting only to non-system fonts
+      if (!is_system_default) {
+        std::string fingerprint = command_line->GetSwitchValueASCII(switches::kFingerprint);
+        uint32_t seed;
+        if (base::StringToUint(fingerprint, &seed)) {
+          uint32_t hash = std::hash<String>{}(family_name);
+          hash = hash ^ seed;
+
+          // Use deterministic probability based on hash
+          if (hash % 3 == 0) {
+            return nullptr;
+          }
+        }
+      }
+    }
+  }
+
