+  // Font fingerprinting protection
+  const base::CommandLine* command_line = base::CommandLine::ForCurrentProcess();
+  if (command_line->HasSwitch(switches::kFingerprint)) {
+    // Define system default fonts that should never be blocked
+    static const char* system_default_fonts[] = {
+      // Windows system fonts
+      "Arial", "Times New Roman", "Courier New", "Segoe UI", "Tahoma", "Verdana",
+      "Georgia", "Trebuchet MS", "Comic Sans MS", "Impact", "Lucida Console",
+      "Microsoft Sans Serif", "Palatino Linotype", "Symbol", "Webdings", "Wingdings",
+      // Linux system fonts
+      "DejaVu Sans", "DejaVu Serif", "DejaVu Sans Mono", "Liberation Sans",
+      "Liberation Serif", "Liberation Mono", "Ubuntu", "Cantarell", "Noto Sans",
+      "Noto Serif", "Noto Sans Mono", "Source Sans Pro", "Source Serif Pro",
+      "Source Code Pro", "Droid Sans", "Droid Serif", "Droid Sans Mono",
+      // macOS system fonts
+      "Helvetica", "Times", "Courier", "Helvetica Neue", "Lucida Grande",
+      "Monaco", "Menlo", "SF Pro Display", "SF Pro Text", "SF Mono",
+      "Apple Color Emoji", "PingFang SC", "PingFang TC", "Hiragino Sans",
+      // Generic font families (CSS)
+      "serif", "sans-serif", "monospace", "cursive", "fantasy", "system-ui"
+    };
+
+    if (creation_params.CreationType() == kCreateFontByFamily) {
+      String font_family = creation_params.Family();
+      
+      // Check if this is a system default font
+      bool is_system_font = false;
+      for (const char* system_font : system_default_fonts) {
+        if (font_family.StartsWithIgnoringASCIICase(system_font) ||
+            font_family.EndsWithIgnoringASCIICase(system_font) ||
+            font_family.ContainsIgnoringASCIICase(system_font)) {
+          is_system_font = true;
+          break;
+        }
+      }
+
+      // Only apply fingerprinting to non-system fonts
+      if (!is_system_font) {
+        std::string fingerprint = command_line->GetSwitchValueASCII(switches::kFingerprint);
+        uint32_t seed;
+        if (base::StringToUint(fingerprint, &seed)) {
+          uint32_t hash = std::hash<String>{}(font_family);
+          hash = hash ^ seed;
+
+          // Use a more conservative approach: only block 25% of non-system fonts
+          if (hash % 4 == 0) {
+            return nullptr;
+          }
+        }
+      }
+    }
+  }
