+  const base::CommandLine* command_line = base::CommandLine::ForCurrentProcess();
+  if (command_line->HasSwitch(switches::kFingerprint)) {
+    if (creation_params.CreationType() == kCreateFontByFamily) {
+      std::string font_family = creation_params.Family().Utf8();
+      
+      // Define basic font list for consistent fingerprinting
+      static const char* basic_fonts[] = {
+        "Arial", "Times New Roman", "Courier New", "Verdana", "Georgia",
+        "Tahoma", "Trebuchet MS", "Comic Sans MS", "Impact", "Calibri",
+        "Cambria", "Consolas", "Segoe UI", "Microsoft YaHei", "SimSun"
+      };
+      
+      // Check if font is in basic list
+      bool is_basic_font = false;
+      for (const char* font : basic_fonts) {
+        if (font_family == font) {
+          is_basic_font = true;
+          break;
+        }
+      }
+      
+      // Get fingerprint seed
+      std::string fingerprint = command_line->GetSwitchValueASCII(switches::kFingerprint);
+      uint32_t fingerprint_hash = std::hash<std::string>{}(fingerprint);
+      
+      if (!is_basic_font) {
+        // Unknown font - use probability-based filtering
+        std::string combined = fingerprint + font_family;
+        uint32_t hash = std::hash<std::string>{}(combined);
+        
+        // Use probability distribution based on font characteristics
+        float base_probability = 0.15f;
+        
+        // Adjust probability based on font name characteristics
+        if (font_family.find("Symbol") != std::string::npos ||
+            font_family.find("Wingdings") != std::string::npos ||
+            font_family.find("Webdings") != std::string::npos) {
+          base_probability = 0.02f; // Very low for symbol fonts
+        } else if (font_family.length() > 20) {
+          base_probability = 0.08f; // Lower for very long font names
+        } else if (font_family.find(" ") != std::string::npos) {
+          base_probability = 0.12f; // Moderate for fonts with spaces
+        }
+        
+        float probability = static_cast<float>(hash) / static_cast<float>(std::numeric_limits<uint32_t>::max());
+        
+        if (probability >= base_probability) {
+          return nullptr;
+        }
+      } else {
+        // Basic font - use fingerprint to determine availability
+        uint32_t font_hash = fingerprint_hash ^ std::hash<std::string>{}(font_family);
+        
+        // Make some basic fonts unavailable based on fingerprint
+        if ((font_family == "Comic Sans MS" && (font_hash % 5) < 3) ||
+            (font_family == "Impact" && (font_hash % 4) < 2) ||
+            (font_family == "Trebuchet MS" && (font_hash % 3) < 1)) {
+          return nullptr;
+        }
+      }
+    }
+  }
