index 3bc82e16bc..f21a28e1e4 100644
--- a/third_party/blink/renderer/core/frame/navigator_device_memory.cc
+++ b/third_party/blink/renderer/core/frame/navigator_device_memory.cc
@@ -4,12 +4,19 @@
 
 #include "third_party/blink/renderer/core/frame/navigator_device_memory.h"
 
+#include "base/command_line.h"
 #include "services/device/public/cpp/device_features.h"
 #include "third_party/blink/public/common/device_memory/approximated_device_memory.h"
+#include "components/ungoogled/ungoogled_switches.h"
 
 namespace blink {
 
 float NavigatorDeviceMemory::deviceMemory() const {
+  // When fingerprinting protection is enabled, return a fixed value of 8GB
+  const base::CommandLine* command_line = base::CommandLine::ForCurrentProcess();
+  if (command_line->HasSwitch(switches::kFingerprint))
+    return 8.0;
+    
   return device::features::IsDeviceMemoryReportingEnabled()
              ? ApproximatedDeviceMemory::GetApproximatedDeviceMemory()
              : 0.0;
 }

 }  // namespace blink
