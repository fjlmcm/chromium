+// Generate deterministic hash using FNV-1a algorithm
+uint32_t GetFNVHash(uint32_t input, uint32_t seed) {
+  uint32_t hash = 2166136261u ^ seed;
+  hash ^= input;
+  hash *= 16777619u;
+  return hash;
